# ============================================================
# PUENTE SUPABASE — Variables de entorno
# ============================================================
# Copiar este archivo como .env y llenar con valores reales
# NUNCA subir .env a Git
# ============================================================

# Supabase
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu_clave_anon_aqui
SUPABASE_SERVICE_KEY=tu_clave_service_role_aqui

# Bridge Security
BRIDGE_SECRET_KEY=tu_clave_secreta_del_bridge

# Plant APIs
# Perenual: https://perenual.com/register (Free: 100 req/dia)
PERENUAL_KEY=tu_api_key_perenual
# Trefle: https://trefle.io (Gratis, 120 req/min)
TREFLE_TOKEN=tu_token_trefle

# Packet Tracer (opcional)
PT_HOST=127.0.0.1
PT_PORT=5000
